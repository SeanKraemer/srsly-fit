# Demo mode runs with seeded read-only data and does not require live services.
APP_MODE=demo

# Required by NextAuth in both demo and live modes.
AUTH_SECRET=replace-with-local-nextauth-secret
AUTH_TRUST_HOST=true

# Required only when APP_MODE=live.
DATABASE_URL=mysql://user:password@127.0.0.1:3306/srsly_fit

# Optional. Exercise video embeds fall back to a static demo video when omitted.
YOUTUBE_API_KEY=

# Optional. Comma-separated local network origins allowed to request the dev server.
# Example: NEXT_ALLOWED_DEV_ORIGINS=10.0.0.12
NEXT_ALLOWED_DEV_ORIGINS=
